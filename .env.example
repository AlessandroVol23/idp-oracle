# Oracle Autonomous AI Database 26ai — get these from the OCI console
# Connect string is the TLS (no-wallet) form, e.g. "myadb_high"
ORACLE_CONNECT_STRING=
ORACLE_USER=idp
ORACLE_PASSWORD=

# Bedrock — Claude Sonnet model id and the region you've enabled it in
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
AWS_REGION=us-east-1

# Used by scripts/seed.ts and the frontend at build time
# Local dev: http://localhost:8787 ; Deployed: the CDK ApiUrl output
API_BASE_URL=http://localhost:8787
VITE_API_BASE_URL=http://localhost:8787
