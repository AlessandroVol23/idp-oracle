# Oracle Database (23ai Free running on ECS Fargate, see docs/01-provision-oracle.md).
# Local: while an SSM port-forward to the bastion is open, point at localhost:1521.
ORACLE_CONNECT_STRING=localhost:1521/FREEPDB1
ORACLE_USER=idp
# This password is used both as the container's SYS/SYSTEM password (Fargate task env)
# and as the password for the `idp` application user created by 000_bootstrap.sql.
# Min 12 chars, at least 1 uppercase + 1 lowercase + 1 digit + 1 special char.
ORACLE_PASSWORD=

# Bedrock — Claude Sonnet model id and the region you've enabled it in
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
AWS_REGION=us-east-1

# Used by scripts/seed.ts and the frontend at build time
# Local dev: http://localhost:8787 ; Deployed: the CDK ApiUrl output
API_BASE_URL=http://localhost:8787
VITE_API_BASE_URL=http://localhost:8787
